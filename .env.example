# ─── Ports ────────────────────────────────────────────────────────────────────
API_PORT=8080
MCP_PORT=3000

# Docker only: host port mappings (overrides which host port maps to the container)
API_HOST_PORT=8080
MCP_HOST_PORT=3000

# ─── Data ─────────────────────────────────────────────────────────────────────
# Data source: "file" (default) or "sqlite"
DATA_SOURCE=file

# Directory for JSON data files (DATA_SOURCE=file)
FILE_DB_DIR=./data

# SQLite database path (DATA_SOURCE=sqlite)
DB_PATH=./data/db.sqlite

# Directory for uploaded images
UPLOADS_DIR=./data/artifacts

# Docker only: host directory mounted into the container
DATA_DIR=./data

# ─── Authentication ────────────────────────────────────────────────────────────
# Set ENABLE_AUTH=true and provide a secret API_KEY to require Bearer token auth
ENABLE_AUTH=false
API_KEY=

# ─── TLS ──────────────────────────────────────────────────────────────────────
# Provide paths to PEM certificate and private key to enable HTTPS
# TLS_CERT=/path/to/cert.pem
# TLS_KEY=/path/to/key.pem
